# AWS Cognito Configuration (PRODUCTION VALUES)
VITE_COGNITO_USER_POOL_ID=us-east-2_sMY1wYEF9
VITE_COGNITO_CLIENT_ID=3issslmbua5d9h5v3ais6iebi2
VITE_AWS_REGION=us-east-2

# VenueScope Analytics Engine URL (your EC2/ECS server running Streamlit on port 8501)
VITE_VENUESCOPE_URL=http://your-ec2-ip:8501

# AWS API Gateway endpoints for Staffing and Leads features (optional overrides)
VITE_STAFFING_API_URL=https://4unsp74svc.execute-api.us-east-2.amazonaws.com/prod
VITE_LEADS_API_URL=https://1vqeyybqrj.execute-api.us-east-2.amazonaws.com

# GraphQL API Configuration (REQUIRED for DynamoDB queries)
# Replace with your actual AppSync GraphQL endpoint
# Example: https://xxxxx.appsync-api.us-east-2.amazonaws.com/graphql
VITE_GRAPHQL_ENDPOINT=https://your-appsync-api.appsync-api.us-east-2.amazonaws.com/graphql

# DynamoDB Table Names (Optional - defaults will be used if not specified)
VITE_SENSOR_DATA_TABLE=SensorData
VITE_VENUE_CONFIG_TABLE=VenueConfig
VITE_OCCUPANCY_METRICS_TABLE=OccupancyMetrics

# AWS IoT Core (Optional - for real-time MQTT streaming)
VITE_IOT_ENDPOINT=a1h5tm3jvbz8cg-ats.iot.us-east-2.amazonaws.com

# SerpAPI Configuration (Optional - for Google Reviews in Pulse Plus)
# Option A: Use Lambda Proxy (RECOMMENDED - no CORS issues)
# Set this to your API Gateway URL WITH the /reviews path
VITE_SERPAPI_PROXY_URL=https://your-api-gateway.execute-api.us-east-2.amazonaws.com/reviews

# Option B: Direct SerpAPI (will fail due to CORS in browser)
# Get your free key at: https://serpapi.com
# Free tier: 100 searches/month
VITE_SERPAPI_KEY=your-serpapi-key-here

# =============================================================================
# VENUESCOPE ANALYTICS ENGINE (venuescope/ directory)
# =============================================================================

# Auth
VENUESCOPE_PIN=change-me-before-deploy

# Database (Phase 2: PostgreSQL replaces SQLite)
DATABASE_URL=postgresql://user:password@your-rds-host:5432/venuescope

# AWS — file storage (Phase 2: S3 replaces local disk)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=venuescope-uploads

# Email alerts — SendGrid (Phase 5)
SENDGRID_API_KEY=SG.your-sendgrid-key
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# SMS alerts — Twilio (Phase 5)
TWILIO_ACCOUNT_SID=ACyour-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Billing — Stripe (Phase 6)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# App
PORT=8501
HOST=0.0.0.0
APP_ENV=production
SECRET_KEY=your-jwt-secret-key-min-32-chars
