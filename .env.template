# ============================================================================
# VenueScope v6 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# ── Venue identity ────────────────────────────────────────────────────────────
# Unique identifier for this installation (used in DynamoDB partition key,
# S3 prefixes, alert messages, and log metadata).
VENUESCOPE_VENUE_ID=your_venue_id_here

# ── AWS credentials ───────────────────────────────────────────────────────────
# IAM user with: DynamoDB read/write on VenueScopeJobs table,
#                S3 read/write on S3_BUCKET,
#                SES send permissions (if using email alerts).
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-2

# ── Storage ───────────────────────────────────────────────────────────────────
# S3 bucket for flagged clip uploads and daily backups.
# Leave empty to disable S3 features (local-only mode).
S3_BUCKET=

# Local directory for SQLite DB, result files, and uploads.
# Defaults to ~/.venuescope (or /data inside Docker).
VENUESCOPE_DATA_DIR=

# ── Alert settings ────────────────────────────────────────────────────────────
# Comma-separated email addresses for theft and camera offline alerts.
ALERT_EMAIL_TO=
# SES-verified sender address (must be verified in AWS SES console).
ALERT_EMAIL_FROM=

# Optional Slack incoming webhook URL (or any JSON POST endpoint).
ALERT_WEBHOOK_URL=

# Minimum number of unrung drinks to trigger a theft alert (default: 5).
ALERT_UNRUNG_THRESHOLD=5

# ── Camera health ─────────────────────────────────────────────────────────────
# Seconds without a frame before a camera is considered offline (default: 600 = 10 min).
CAMERA_OFFLINE_THRESHOLD_SEC=600

# ── Worker settings ───────────────────────────────────────────────────────────
# Maximum number of jobs to process in parallel (default: 4).
VENUESCOPE_WORKERS=4

# Minimum free RAM (MB) required before starting a job (default: 1024 = 1 GB).
VENUESCOPE_MIN_RAM_MB=1024

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO).
VENUESCOPE_LOG_LEVEL=INFO

# Optional file path for structured JSON logs (in addition to stdout).
# Example: /data/logs/venuescope.log
VENUESCOPE_LOG_FILE=

# ── DVR Folder Watcher ────────────────────────────────────────────────────────
# Colon-separated list of directories to watch for new video files.
# Leave empty to disable. Example: /mnt/dvr/bar:/mnt/dvr/entrance
VENUESCOPE_WATCH_FOLDERS=

# Default analysis mode for folder-watcher jobs (default: drink_count).
# Comma-separated for multi-mode: drink_count,people_count
VENUESCOPE_WATCH_MODE=drink_count

# ── AppSync / GraphQL (React dashboard) ──────────────────────────────────────
# Set in src/aws-exports.js or amplify/.../aws-exports.js, not here.
# Documented for reference only:
#   aws_appsync_graphqlEndpoint
#   aws_cognito_region
#   aws_user_pools_id
#   aws_user_pools_web_client_id
